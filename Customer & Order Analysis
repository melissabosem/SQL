#In this SQL, I'm querying a database with multiple tables in it to quantify statistics about customer and order data. 

-- #1. Find all results with true Order IDs
SELECT * FROM BIT_DB.customers
WHERE length(order_id) = 6
AND order_id <> 'Order ID';

-- #2. How many orders were placed in January?
SELECT COUNT(distinct orderid)
FROM BIT_DB.JanSales
WHERE length(orderid) = 6
AND orderid <> 'Order ID';

-- #3. How many of the January orders were for an iPhone?
SELECT COUNT(distinct orderid)
FROM BIT_DB.JanSales
WHERE product = 'iPhone'
AND length(orderid) = 6
AND orderid <> 'Order ID';

-- #4. Select the customer account number for all the orders placed in February
SELECT DISTINCT acctnum FROM BIT_DB.customers AS cust
JOIN BIT_DB.FebSales AS Feb 
ON cust.order_id=Feb.orderid
AND length(orderid) = 6
AND orderid <> 'Order ID';

-- #5. Which product was the cheapest one sold in January and what was the price?
SELECT distinct product
, price FROM BIT_DB.JanSales
WHERE price IN (SELECT min(price) FROM BIT_DB.JanSales)
GROUP BY product;

-- #6. What is the total revenue for each product sold in January?
SELECT distinct product
, ROUND(sum(quantity)*price, 2) AS revenue
FROM BIT_DB.JanSales
GROUP BY product;

-- #7. Which products were sold in February at 548 Lincoln St, Seattle; how many of each were sold; what was the total revenue?
SELECT product
, sum(quantity)
, sum(quantity)* price AS revenue
FROM BIT_DB.FebSales
WHERE location = '548 Lincoln St, Seattle, WA 98101'
GROUP BY product;

-- #8. How many customers ordered more than 2 products at a time in February? What was the average amount spent by those customers?
SELECT 
COUNT (distinct cust.acctnum)
, ROUND (avg(quantity*price), 2)
FROM BIT_DB.FebSales AS Feb
LEFT JOIN BIT_DB.customers AS cust
ON Feb.orderid = cust.order_id
WHERE Feb.Quantity > 2
AND length (orderid)=6
AND orderid <> 'Order ID';

-- #9. How many of each type of headphone were sold in February?
SELECT product
, sum(quantity)
FROM BIT_DB.FebSales
WHERE product LIKE '%Headphones%'
AND length(orderid) = 6
AND orderid <> 'Order ID'
GROUP BY product;

-- #10. What was the average amount spent per account in February?
SELECT ROUND (sum(quantity)*price/count(cust.acctnum), 2)
FROM BIT_DB.FebSales AS Feb
LEFT JOIN BIT_DB.customers AS cust
ON Feb.orderid = cust.order_id
AND length(orderid) = 6
AND orderid <> 'Order ID';

-- #11. Find order ids from Georgia where the order has an average price greater than $1000. Only find dates beginning with '04/1'
SELECT orderID 
FROM BIT_DB.AprSales
WHERE orderdate LIKE '04/1%'
AND location LIKE '%GA%'
AND length(orderid) = 6
AND orderid <> 'Order ID'
GROUP BY orderid
HAVING avg(price) > 1000;

-- #12. Can you reverse engineer a SQL query to produce a specific table?
SELECT location
, orderid
FROM BIT_DB.MaySales
WHERE orderID LIKE '1943_5'
AND length(orderid) = 6
AND orderid <> 'Order ID'
ORDER BY orderID;

-- #13. Which product brought in the most revenue in January? How much revenue did it bring in total?
SELECT product
, sum(quantity*price) AS revenue 
FROM BIT_DB.JanSales
GROUP BY product
ORDER BY revenue desc
LIMIT 1;
